---
/**
 * Showcase section — editorial headline + body next to either an
 * iPhone screenshot (kind="screenshot", framed in CSS with a rounded
 * bezel), a full editorial photograph (kind="photo"), or a hand-built
 * app-UI recreation passed via the default slot (kind="custom").
 */

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

export interface Props {
  eyebrow: string;
  headline: string;
  headlineAccent?: string;
  /** Filename (with extension) inside public/images. Unused for kind="custom". */
  image?: string;
  alt?: string;
  body?: string;
  device?: 'left' | 'right';
  kind?: 'screenshot' | 'photo' | 'custom';
  imageWidth?: number;
  imageHeight?: number;
}

const {
  eyebrow,
  headline,
  headlineAccent,
  image,
  alt,
  body,
  device = 'right',
  kind = 'screenshot',
  imageWidth = kind === 'screenshot' ? 1320 : 1024,
  imageHeight = kind === 'screenshot' ? 2688 : 683,
} = Astro.props;

const deviceOrder = device === 'right' ? 'md:order-2' : 'md:order-1';
const copyOrder = device === 'right' ? 'md:order-1' : 'md:order-2';
const deviceAlign = device === 'right' ? 'md:ml-auto md:mr-0' : 'md:mr-auto md:ml-0';

// Mirror text alignment around the visual so each pair feels balanced.
const textAlignClass = device === 'right' ? 'md:text-right' : 'md:text-left';
const bodyAlignClass = device === 'right' ? 'md:ml-auto' : '';
---

<section class={`relative overflow-hidden bg-sun-ink text-sun-text ${device === 'right' ? 'sun-wash' : 'sun-wash--left'}`}>
  <div class="showcase-section-inner relative mx-auto max-w-8xl px-6 sm:px-8 lg:px-10 pt-24 sm:pt-32 pb-24 sm:pb-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 sm:gap-12 md:gap-16 lg:gap-20 items-center">
      <div class={`md:col-span-5 lg:col-span-5 relative z-10 ${copyOrder} ${textAlignClass}`}>
        <p class="reveal-eyebrow text-[12px] uppercase tracking-[0.24em] text-sun-textMuted">
          {eyebrow}
        </p>

        <h2 class="showcase-headline mt-6 sm:mt-7 display-section text-[clamp(2.25rem,6vw,5rem)] text-balance">
          <span class="block">{headline}</span>
          {headlineAccent && (
            <span class="block text-dim">{headlineAccent}</span>
          )}
        </h2>

        {body && (
          <p class={`reveal reveal-delay-2 mt-6 max-w-md 2xl:max-w-lg text-[16px] sm:text-[17px] 2xl:text-[19px] leading-[1.55] text-sun-textSoft ${bodyAlignClass}`}>
            {body}
          </p>
        )}
      </div>

      <div class={`md:col-span-7 lg:col-span-7 min-w-0 overflow-visible ${deviceOrder}`}>
        {kind === 'custom' ? (
          <div class="reveal-image relative">
            <slot />
          </div>
        ) : kind === 'screenshot' ? (
          <div class={`reveal-image showcase-phone relative mx-auto ${deviceAlign}`}>
            <img
              src={`${base}images/${image}`}
              alt={alt}
              loading="lazy"
              decoding="async"
              class="w-full h-auto block"
              width={imageWidth}
              height={imageHeight}
            />
          </div>
        ) : (
          <div class={`reveal-image showcase-photo relative mx-auto ${deviceAlign}`}>
            <img
              src={`${base}images/${image}`}
              alt={alt}
              loading="lazy"
              decoding="async"
              class="w-full h-auto block"
              width={imageWidth}
              height={imageHeight}
            />
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Raw simulator screenshot framed in CSS: rounded "device" mask with a
     hairline ring and a deep soft shadow. Keeps assets light — no baked
     bezel art to re-export per locale. */
  .showcase-phone {
    width: min(78%, 22rem);
    border-radius: clamp(28px, 9%, 54px);
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(84, 56, 18, 0.06),
      0 40px 90px -35px rgba(148, 94, 26, 0.35);
  }
  @media (min-width: 768px) {
    .showcase-phone {
      width: min(100%, 24rem);
    }
  }

  /* Editorial photograph: generous radius, softly lifted. */
  .showcase-photo {
    width: min(100%, 44rem);
    border-radius: 28px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(84, 56, 18, 0.05),
      0 40px 90px -40px rgba(148, 94, 26, 0.32);
  }
</style>
