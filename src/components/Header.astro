---
import { site } from '../config/site';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getLocalizedHashPath, useTranslations } from '../i18n/utils';
import LanguageSelector from './LanguageSelector.astro';

const currentLocale = Astro.currentLocale || 'en';
const t = useTranslations(currentLocale);

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const isExternalAppStoreUrl = site.appStoreUrl.startsWith('http');
const featuresHref = getLocalizedHashPath(currentLocale, '/', 'features');
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 backdrop-blur-xl site-header-chrome"
>
  <div class="mx-auto max-w-8xl px-6 sm:px-8 lg:px-10 h-14 flex items-center justify-between">
    <a href={getRelativeLocaleUrl(currentLocale, '/')} class="flex items-center gap-2.5 group" aria-label={t.a11y.homeLink}>
      <img
        src={`${base}images/icon-192.png`}
        alt=""
        width="30"
        height="30"
        class="w-[30px] h-[30px] rounded-[7px] shadow-sm"
      />
      <span class="text-[17px] font-semibold tracking-[-0.015em] text-sun-text group-hover:text-sun-redDeep transition-colors">
        Soleil
      </span>
    </a>
    <nav class="flex items-center gap-1.5 text-[13.5px]">
      <a href={featuresHref} class="hidden sm:inline-flex px-3 py-2 text-sun-textSoft hover:text-sun-text transition-colors">{t.header.features}</a>
      {currentLocale === 'en' && (
        <a href="/guides/" class="hidden sm:inline-flex px-3 py-2 text-sun-textSoft hover:text-sun-text transition-colors">Guides</a>
      )}
      <a href={getRelativeLocaleUrl(currentLocale, '/support')} class="hidden md:inline-flex px-3 py-2 text-sun-textSoft hover:text-sun-text transition-colors">{t.header.support}</a>
      <span class="inline-flex mr-1 sm:mr-2">
        <LanguageSelector />
      </span>
      {isExternalAppStoreUrl ? (
        <a
          href={site.appStoreUrl}
          target="_blank"
          rel="noopener"
          class="header-cta ml-1 inline-flex items-center gap-1.5 whitespace-nowrap rounded-full px-4 py-2 text-[13.5px] font-semibold text-white"
        >
          {t.header.download}
        </a>
      ) : (
        <span
          class="header-cta--soon ml-1 inline-flex items-center gap-1.5 whitespace-nowrap rounded-full px-4 py-2 text-[13.5px] font-medium text-sun-textSoft cursor-default select-none"
        >
          <span class="header-cta__dot" aria-hidden="true"></span>
          {t.cta.comingSoonShort}
        </span>
      )}
    </nav>
  </div>
</header>

<div aria-hidden="true" class="h-14"></div>

<style is:global>
  /* Light, warm, glossy chrome floating over the bright page. */
  .site-header-chrome {
    background-color: rgba(255, 251, 244, 0.78);
    border-bottom: 1px solid rgba(36, 28, 17, 0.06);
  }

  /* Live "Download" pill: the brand gradient, with a gentle lift. */
  .header-cta {
    background-image: linear-gradient(135deg, #FFA51F, #FF7A00 60%, #F0570A);
    box-shadow: 0 6px 16px -6px rgba(240, 87, 10, 0.5);
    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 300ms ease-out;
  }
  .header-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 22px -8px rgba(240, 87, 10, 0.55);
  }

  /* Non-clickable "Coming soon" pill (shown until the App Store URL
     is live): quiet neutral surface with the brand status dot. */
  .header-cta--soon {
    background-color: rgba(36, 28, 17, 0.045);
    box-shadow: inset 0 0 0 1px rgba(36, 28, 17, 0.09);
  }
  .header-cta__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #FF7A00;
  }
</style>
