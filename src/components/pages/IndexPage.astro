---
import Base from '../../layouts/Base.astro';
import Hero from '../Hero.astro';
import Showcase from '../Showcase.astro';
import SplitHeadline from '../SplitHeadline.astro';
import BentoGrid from '../BentoGrid.astro';
import PartOfIphone from '../PartOfIphone.astro';
import SunWindowCluster from '../ui/SunWindowCluster.astro';
import RealSunCluster from '../ui/RealSunCluster.astro';
import SessionCluster from '../ui/SessionCluster.astro';
import DayArc from '../DayArc.astro';
import FaqSection from '../FaqSection.astro';
import GuidesTeaser from '../GuidesTeaser.astro';
import { useTranslations } from '../../i18n/utils';
import { homeFaqs } from '../../data/homeFaq';

const currentLocale = Astro.currentLocale ?? 'en';
const t = useTranslations(currentLocale);

// SEO surfaces (FAQ, guides teaser, structured data) are English-only —
// the guides target English search queries and have no locale variants.
const isEnglish = currentLocale === 'en';

const jsonLd = isEnglish
  ? [
      {
        '@context': 'https://schema.org',
        '@type': 'MobileApplication',
        name: 'Soleil',
        operatingSystem: 'iOS, watchOS',
        applicationCategory: 'HealthApplication',
        description: t.meta.description,
        offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
        author: { '@type': 'Organization', name: 'Soleil', url: Astro.site?.toString() },
      },
      {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: homeFaqs.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      },
      {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Soleil',
        url: Astro.site?.toString(),
      },
    ]
  : [];
---

<Base
  title={t.meta.title}
  description={t.meta.description}
  jsonLd={jsonLd}
>
  <Hero />

  <Showcase
    eyebrow={t.showcaseNow.eyebrow}
    headline={t.showcaseNow.headline}
    headlineAccent={t.showcaseNow.headlineAccent}
    body={t.showcaseNow.body}
    device="right"
    kind="custom"
  >
    <SunWindowCluster />
  </Showcase>

  <Showcase
    eyebrow={t.showcaseRealSun.eyebrow}
    headline={t.showcaseRealSun.headline}
    headlineAccent={t.showcaseRealSun.headlineAccent}
    body={t.showcaseRealSun.body}
    device="left"
    kind="custom"
  >
    <RealSunCluster />
  </Showcase>

  <DayArc />

  <Showcase
    eyebrow={t.showcaseRoutine.eyebrow}
    headline={t.showcaseRoutine.headline}
    headlineAccent={t.showcaseRoutine.headlineAccent}
    body={t.showcaseRoutine.body}
    device="right"
    kind="custom"
  >
    <SessionCluster />
  </Showcase>

  <SplitHeadline
    eyebrow={t.splitHeadlinePrivacy.eyebrow}
    first={t.splitHeadlinePrivacy.first}
    second={t.splitHeadlinePrivacy.second}
    body={t.splitHeadlinePrivacy.body}
  />

  <BentoGrid />

  <PartOfIphone />

  {isEnglish && <GuidesTeaser />}

  {isEnglish && <FaqSection />}
</Base>
