---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<Base
  title={t.termsPage.metaTitle}
  description={t.termsPage.metaDescription}
>
  <section class="relative bg-sun-ink text-sun-text">
    <div class="mx-auto max-w-3xl px-6 sm:px-8 lg:px-10 pt-20 sm:pt-28 pb-24 sm:pb-32">
      <div>
        <p class="reveal-eyebrow text-[12px] uppercase tracking-[0.24em] text-sun-textMuted">{t.termsPage.eyebrow}</p>
        <h1 class="reveal-lines mt-6 sm:mt-7 display-section text-[clamp(2.25rem,6vw,5rem)]">
          <span class="reveal-line"><span>{t.termsPage.headline}&nbsp;<span class="text-dim">{t.termsPage.headlineDim}</span></span></span>
        </h1>
        <p class="mt-5 text-sun-textDim text-[13.5px]">{t.termsPage.lastUpdated}</p>
      </div>

      <p class="reveal reveal-delay-1 mt-10 text-[17px] leading-[1.6] text-sun-textSoft">
        {t.termsPage.intro}
      </p>

      <div class="reveal reveal-delay-2 mt-12 rounded-[24px] bg-sun-card ring-soft p-7 sm:p-8">
        <p class="text-[12px] uppercase tracking-[0.18em] text-sun-textMuted">{t.termsPage.tldrTitle}</p>
        <ul class="mt-5 space-y-3 text-[15.5px] leading-[1.5] text-sun-textSoft">
          {t.termsPage.tldr.map((line) => (
            <li class="flex items-start gap-3">
              <span aria-hidden="true" class="mt-[0.55rem] inline-block w-1.5 h-1.5 rounded-full bg-sun-red shrink-0"></span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-14 sm:mt-20 space-y-12">
        {t.termsPage.sections.map((section, i) => (
          <div class={`reveal reveal-delay-${Math.min(i % 5 + 1, 5)}`}>
            <h2 class="text-[12px] uppercase tracking-[0.18em] text-sun-textMuted">{section.title}</h2>
            <p class="mt-4 text-[16.5px] leading-[1.65] text-sun-textSoft">{section.body}</p>
            {section.bullets && (
              <ul class="mt-4 space-y-3 text-[16px] leading-[1.6] text-sun-textSoft list-disc list-outside pl-5 marker:text-sun-red/60">
                {section.bullets.map((b) => <li>{b}</li>)}
              </ul>
            )}
            {section.link && (
              <a
                href={section.link.href}
                class="mt-3 inline-flex items-center gap-1 text-[14px] text-sun-red hover:opacity-90 transition-opacity"
                target="_blank"
                rel="noopener noreferrer"
              >
                {section.link.label}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="7" y1="17" x2="17" y2="7"/>
                  <polyline points="7 7 17 7 17 17"/>
                </svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
