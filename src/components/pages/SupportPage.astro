---
import Base from '../../layouts/Base.astro';
import { site } from '../../config/site';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);
const supportEmail = site.supportEmail;
---

<Base
  title={t.supportPage.metaTitle}
  description={t.supportPage.metaDescription}
>
  <section class="relative bg-sun-ink text-sun-text">
    <div class="mx-auto max-w-3xl px-6 sm:px-8 lg:px-10 pt-20 sm:pt-28 pb-24 sm:pb-32">
      <div>
        <p class="reveal-eyebrow text-[12px] uppercase tracking-[0.24em] text-sun-textMuted">{t.supportPage.eyebrow}</p>
        <h1 class="reveal-lines mt-6 sm:mt-7 display-section text-[clamp(2.25rem,6vw,5rem)] text-balance">
          <span class="reveal-line"><span>{t.supportPage.headline}&nbsp;<span class="text-dim">{t.supportPage.headlineDim}</span></span></span>
        </h1>
        <p class="mt-8 text-[17px] leading-[1.55] text-sun-textSoft">
          {t.supportPage.intro}
        </p>
      </div>

      <div class="reveal reveal-delay-1 mt-12 rounded-[24px] bg-sun-card ring-soft p-7 sm:p-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5">
        <div>
          <p class="text-[12px] uppercase tracking-[0.18em] text-sun-textMuted">{t.supportPage.contactTitle}</p>
          <p class="mt-2 text-sun-text text-[17px]">
            <a href={`mailto:${supportEmail}`} class="text-sun-red font-medium hover:opacity-90 transition-opacity">{supportEmail}</a>
          </p>
        </div>
        <a
          href={`mailto:${supportEmail}`}
          class="inline-flex items-center justify-center rounded-full bg-sun-text text-sun-ink px-5 py-3 text-[14px] font-medium hover:opacity-90 transition-opacity"
        >
          {t.supportPage.contactButton}
        </a>
      </div>

      <h2 class="reveal reveal-delay-2 mt-20 text-[12px] uppercase tracking-[0.18em] text-sun-textMuted">
        {t.supportPage.faqTitle}
      </h2>
      <ul class="mt-6 divide-y divide-white/[0.06] rounded-[24px] bg-sun-card ring-soft overflow-hidden">
        {t.supportPage.faqs.map((faq) => (
          <li class="reveal p-6 sm:p-7">
            <h3 class="text-[15.5px] font-semibold text-sun-text">{faq.q}</h3>
            <p class="mt-2 text-[15px] leading-[1.6] text-sun-textSoft">{faq.a}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>
