---
import AppStoreBadge from './AppStoreBadge.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="relative isolate overflow-hidden bg-sun-ink text-sun-text">
  {/* Photographic backdrop — the same dappled-shade portrait that opens
      the app's onboarding, so the site and the first run share a face.
      The page stays light: instead of darkening the photo, a warm cream
      scrim opens from the text corner and the bottom dissolves into the
      page surface, so the hero reads like a sun-flooded magazine spread. */}
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    {/* The same portrait the app uses on its paywall, so the site and the
        purchase moment share a face. It is a 1:1 source anchored to the
        right edge rather than stretched full-bleed — the open sea on its
        left carries the headline, and a square never gets upscaled into
        a wide frame. */}
    <img
      src={`${base}images/photo-sunscreen.jpg`}
      alt=""
      class="hero-photo absolute inset-y-0 right-0 h-full w-full md:w-[66%] lg:w-[62%] object-cover"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 hero-scrim"></div>
  </div>

  <div class="hero-inner relative mx-auto max-w-8xl px-6 sm:px-8 lg:px-10 pt-20 sm:pt-32 lg:pt-36 pb-24 sm:pb-40">

    <p class="hero-rise hero-rise-1 text-[12px] font-semibold uppercase tracking-[0.24em] text-sun-redDeep">
      {t.hero.eyebrow}
    </p>

    {/* Brand line. Largest type on the site — every other section
        headline steps down from here. Entrance is a quick one-time
        rise so the line lands with intent, not a slow scroll reveal. */}
    <h1 class="hero-headline mt-7 sm:mt-9 display text-[clamp(2.75rem,9vw,7rem)]">
      <span class="hero-rise hero-rise-2 block">{t.hero.title}</span>
      <span class="hero-rise hero-rise-3 block text-dim">{t.hero.titleAccent}</span>
    </h1>

    <p class="hero-rise hero-rise-4 mt-8 max-w-xl text-[18px] sm:text-[20px] leading-[1.4] text-sun-textSoft">
      {t.hero.body}
    </p>

    <div class="hero-actions hero-rise hero-rise-5 mt-10 sm:mt-12 flex flex-wrap items-center gap-5">
      <AppStoreBadge height={56} />
      <span class="text-[13.5px] text-sun-textMuted">
        {t.hero.badgeLabel}
      </span>
    </div>
  </div>
</section>

<style is:global>
  /* Keeps her face and the sunscreen gesture in frame while the horizon
     sits behind the headline. */
  .hero-photo {
    object-position: 54% 42%;
  }

  /* Readability scrim: warm cream holding the left half, feathering out
     across the photo's left edge so there is no hard seam, plus a
     dissolve into the page surface at the bottom. The photo stays
     bright — the page never goes dark. */
  .hero-scrim {
    background:
      linear-gradient(to bottom, rgba(255, 251, 244, 0.18) 0%, rgba(255, 251, 244, 0) 34%, rgba(255, 251, 244, 0.22) 74%, #FFFBF4 100%),
      linear-gradient(96deg, #FFFBF4 0%, #FFFBF4 30%, rgba(255, 249, 238, 0.86) 42%, rgba(255, 249, 238, 0.32) 56%, rgba(255, 249, 238, 0) 70%);
  }

  @media (max-width: 767px) {
    /* Portrait viewport: photo goes full width behind the copy, so the
       scrim carries readability vertically instead. */
    .hero-photo { object-position: 58% 32%; }
    .hero-scrim {
      background:
        linear-gradient(to bottom, rgba(255, 251, 244, 0.78) 0%, rgba(255, 251, 244, 0.62) 40%, rgba(255, 251, 244, 0.82) 76%, #FFFBF4 100%);
    }
  }

  /* One-time entrance cascade. Pure CSS keyframes (not scroll-gated)
     so the hero animates even if motion.ts is slow, and content is
     never hidden if CSS animations are unsupported. */
  .hero-rise {
    opacity: 0;
    animation: heroRise 950ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-rise-1 { animation-delay: 80ms; }
  .hero-rise-2 { animation-delay: 180ms; }
  .hero-rise-3 { animation-delay: 300ms; }
  .hero-rise-4 { animation-delay: 460ms; }
  .hero-rise-5 { animation-delay: 600ms; }
  @keyframes heroRise {
    from {
      opacity: 0;
      transform: translateY(26px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-rise {
      opacity: 1;
      animation: none;
    }
  }
</style>
